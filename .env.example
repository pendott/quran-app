# Copy to .env.local and fill in values.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/quran_class"

# Auth.js — required in production
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# AUTH_URL="https://your-domain.com"

# Cron (GET/POST /api/cron/reminders)
CRON_SECRET="long-random-string"

# Payments
# mock (default): local FPX-style wizard. billplz: create Billplz bill (needs keys).
PAYMENT_PROVIDER="mock"
PAYMENT_WEBHOOK_SECRET="shared-secret-for-signed-json-webhook"
# Billplz (when PAYMENT_PROVIDER=billplz)
BILLPLZ_API_KEY=""
BILLPLZ_COLLECTION_ID=""
# BILLPLZ_SANDBOX="0"
# BILLPLZ_CALLBACK_TRUST="1"

# Email reminders (optional — without RESEND_API_KEY, cron still marks reminders SENT as stub)
RESEND_API_KEY=""
RESEND_FROM="Quran Class <onboarding@resend.dev>"

# Optional Zoom stub on new bookings
# ZOOM_USE_STUB="1"
