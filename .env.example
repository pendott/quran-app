# Database (required)
# Local npm: localhost. Docker Compose web container uses postgres hostname (set in docker-compose.yml).
DATABASE_URL="postgresql://quran:quran_dev_password@localhost:5432/quran_class_saas?schema=public"

# Auth (required in production)
# Required for sign-in (min ~32 chars). Docker: set this in .env before `docker compose up`.
AUTH_SECRET="dev-secret-at-least-32-characters-long"
AUTH_URL="http://localhost:3000"

# Payments: mock (local demo) or billplz (pilot/production)
PAYMENT_PROVIDER=mock
# PAYMENT_PROVIDER=billplz
# BILLPLZ_API_KEY=
# BILLPLZ_COLLECTION_ID=
# BILLPLZ_X_SIGNATURE=
# BILLPLZ_SANDBOX=1
# BILLPLZ_API_BASE_URL=https://www.billplz-sandbox.com/api/v3

# Optional: JSON webhook HMAC (dev/mock) when not using Billplz form callback
# PAYMENT_WEBHOOK_SECRET=

# Cron (Vercel): reminder dispatch
# CRON_SECRET=

# Email reminders (optional for pilot)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Zoom Server-to-Server OAuth (Marketplace app → Server-to-Server OAuth)
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_HOST_USER_ID=host@yourzoomaccount.com
# ZOOM_USE_STUB=1
# ZOOM_SECRET_TOKEN=   # optional: Event Subscriptions verification only
